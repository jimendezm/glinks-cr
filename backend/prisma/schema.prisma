// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Connection speed plans offered by the company.
model PlanCatalog {
  id      Int      @id @default(autoincrement())
  plan    String   @unique
  clients Client[]
}

// Sector antennas' names.
model SectorCatalog {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  clients Client[]
}

// Access point type.
model ApTypeCatalog {
  id      Int      @id @default(autoincrement())
  ap_type String   @unique
  clients Client[]
}

// User role.
model RoleCatalog {
  id    Int    @id @default(autoincrement())
  role  String @unique
  users User[]
}

model Client {
  id                Int           @id @default(autoincrement())
  national_id       String        @unique
  first_name        String
  last_name_1       String
  last_name_2       String
  primary_phone     String
  secondary_phone   String?
  email             String?
  address           String
  installation_date DateTime      @default(now())
  plan              PlanCatalog   @relation(fields: [plan_id], references: [id])
  plan_id           Int
  sector            SectorCatalog @relation(fields: [sector_id], references: [id])
  sector_id         Int
  ap_type           ApTypeCatalog @relation(fields: [ap_type_id], references: [id])
  ap_type_id        Int
  equipment         Equipment[]
  maintenance       Maintenance[]
}

model Equipment {
  id        Int     @id @default(autoincrement())
  type      String
  client    Client? @relation(fields: [client_id], references: [id])
  client_id Int?
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  password     String
  role         RoleCatalog   @relation(fields: [role_id], references: [id])
  role_id      Int
  maintenances Maintenance[]
}

model Maintenance {
  id             Int      @id @default(autoincrement())
  date           DateTime @default(now())
  description    String
  client         Client   @relation(fields: [client_id], references: [id])
  client_id      Int
  responsible    User     @relation(fields: [responsible_id], references: [id])
  responsible_id Int
  new_router     Int?
  new_poe        Int?
}
