generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique
  password     String
  role         Role          @default(admin)
  createdAt    DateTime      @default(now())
  maintenances Maintenance[]
}

enum Role {
  admin
  tecnico
}

model PhysicalClient {
  id              String        @id @default(uuid())
  national_id     String        @unique // Cédula.
  name            String
  last_name_1     String
  last_name_2     String
  primary_phone   String
  secondary_phone String?
  email           String?
  address         String
  exonerated      Boolean
  createdAt       DateTime      @default(now())
  maintenances    Maintenance[]
  invoices        Invoice[]
}

model LegalClient {
  id              String        @id @default(uuid())
  legal_id        String        @unique
  name            String
  primary_phone   String
  secondary_phone String?
  email           String?
  address         String
  exonerated      Boolean
  createdAt       DateTime      @default(now())
  maintenances    Maintenance[]
  invoices        Invoice[]
}

model Maintenance {
  id                 String   @id @default(uuid())
  fecha              DateTime @default(now())
  descripcion        String
  physical_client_id String
  legal_client_id    String
  responsible_id     String

  physical_client     PhysicalClient       @relation(fields: [physical_client_id], references: [id])
  legal_client        LegalClient          @relation(fields: [physical_client_id], references: [id])
  responsible         User                 @relation(fields: [responsible_id], references: [id])
  maintenanceProducts MaintenanceProduct[]
}

model MaintenanceProduct {
  amount         Int
  maintenance_id String
  product_id     String

  maintenace Maintenance @relation(fields: [maintenance_id], references: [id])
  product    Product     @relation(fields: [product_id], references: [id])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  type        String
  description String
  unit_price  Float
  billable    Boolean
  createdAt   DateTime @default(now())

  serviceProductInvoice  ServiceProductInvoice[]
  physicalProductInvoice PhysicalProductInvoice[]
  maintenanceProduct     MaintenanceProduct[]
}

model Invoice {
  id                 String   @id @default(uuid())
  fecha              DateTime @default(now())
  physical_client_id String?
  legal_client_id    String?

  physicalClient         PhysicalClient?          @relation(fields: [physical_client_id], references: [id])
  clienteJuridico        LegalClient?             @relation(fields: [legal_client_id], references: [id])
  serviceProductInvoice  ServiceProductInvoice[]
  physicalProductInvoice PhysicalProductInvoice[]
}

model ServiceProductInvoice {
  invoice_id String
  product_id String
  start_date DateTime // Start date of the service paid.
  end_date   DateTime // End date of the service paid.

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])
}

model PhysicalProductInvoice {
  invoice_id String
  product_id String
  amount     Int

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])
}
